<Window x:Class="Tatsuno.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Tatsuno.WpfApp.ViewModels"
        mc:Ignorable="d"
        Title="Tatsuno Master"
        Height="980"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5"
        FontFamily="Segoe UI">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="RoundedBtn" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NozzleBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="4,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#E5E7EB" Padding="4,2">
            <StatusBarItem Content="Состояние:"/>
            <StatusBarItem Content="{Binding PollState}" FontWeight="SemiBold"/>
            <Separator/>
            <StatusBarItem Content="Активный:"/>
            <StatusBarItem Content="{Binding LiftedInfo}"/>
            <Separator/>
            <StatusBarItem Content="OK:"/>
            <StatusBarItem Content="{Binding FramesOk}" FontWeight="SemiBold" Foreground="#22C55E"/>
            <StatusBarItem Content="BAD:"/>
            <StatusBarItem Content="{Binding FramesBadBcc}" FontWeight="SemiBold" Foreground="#EF4444"/>
            <Separator/>
            <StatusBarItem Content="RX:"/>
            <StatusBarItem Content="{Binding LastRx, StringFormat=HH:mm:ss.fff}"/>
        </StatusBar>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- Settings Panel -->
            <Border Grid.Row="0" Background="White" Padding="10,8" CornerRadius="6" Margin="0,0,0,8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="COM:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                    <ComboBox Width="110" Height="26" ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort}" Margin="0,0,4,0"/>
                    <Button Height="26" Width="26" Content="&#x21BB;" Command="{Binding RefreshPortsCommand}" ToolTip="Обновить порты" Style="{StaticResource RoundedBtn}" Background="#F3F4F6" Margin="0,0,12,0"/>

                    <TextBlock Text="Скорость:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="60" Height="26" Text="{Binding BaudRate}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,12,0"/>

                    <TextBlock Text="Четность:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="75" Height="26" ItemsSource="{Binding ParityValues}" SelectedItem="{Binding Parity}" Margin="0,0,12,0"/>

                    <TextBlock Text="Биты:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="32" Height="26" Text="{Binding DataBits}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,12,0"/>

                    <TextBlock Text="Стоп:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="60" Height="26" ItemsSource="{Binding StopBitsValues}" SelectedItem="{Binding StopBits}" Margin="0,0,16,0"/>

                    <Ellipse Width="10" Height="10" Fill="{Binding ConnectionStatusBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Height="26" Padding="12,0" Content="Подключить" Command="{Binding ConnectCommand}"
                            Style="{StaticResource RoundedBtn}" Background="#22C55E" Foreground="White" FontWeight="SemiBold" Margin="0,0,4,0"/>
                    <Button Height="26" Padding="12,0" Content="Отключить" Command="{Binding DisconnectCommand}"
                            Style="{StaticResource RoundedBtn}" Background="#EF4444" Foreground="White" FontWeight="SemiBold" Margin="0,0,16,0"/>

                    <TextBlock Text="Лог:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" FontSize="11"/>
                    <TextBlock Text="{Binding LogFilePath}" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="11"/>
                </WrapPanel>
            </Border>

            <!-- ТРК Tatsuno — пистолеты по адресам -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Posts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="{Binding BorderBrush}" BorderThickness="2" CornerRadius="6" Margin="4" Padding="12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding SelectCommand}"/>
                            </Border.InputBindings>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                                    <DockPanel>
                                        <Ellipse Width="12" Height="12" Fill="{Binding StatusBrush}" DockPanel.Dock="Left" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Header}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <!-- Nozzles + Save Button -->
                                <Grid Grid.Row="1" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ItemsControl Grid.Column="0" ItemsSource="{Binding Nozzles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,3" Height="32">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Command="{Binding SelectCommand}"
                                                            Background="{Binding ProductBrush}" Foreground="White" FontSize="11"
                                                            Content="{Binding ProductName}" Style="{StaticResource NozzleBtn}"/>
                                                    <TextBox Grid.Column="1" Margin="4,0" FontSize="13" FontFamily="Consolas"
                                                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                             Text="{Binding PriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TotalsVolumeText}" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right" Foreground="#9CA3AF"/>
                                                        <TextBlock Text="{Binding TotalsAmountText}" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right" Foreground="#9CA3AF"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Grid.Column="1" Margin="6,0,0,0" Padding="10,4" VerticalAlignment="Top"
                                            Content="Сохранить" Command="{Binding SavePricesCommand}"
                                            Style="{StaticResource RoundedBtn}" Background="#F3F4F6" FontSize="11"/>
                                </Grid>

                                <!-- Live Display -->
                                <Border Grid.Row="2" Background="#F0FDF4" CornerRadius="6" Padding="10,6" Margin="0,0,0,6" BorderBrush="#D1FAE5" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Active nozzle + product header -->
                                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                                   Text="{Binding ActiveNozzleProductText}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#059669"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Сумма" Foreground="#059669" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LiveAmountText}" FontSize="30" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#1F2937"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Объём" Foreground="#059669" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LiveVolumeText}" FontSize="26" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#1F2937"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Цена" Foreground="#059669" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LivePriceText}" FontSize="20" FontFamily="Consolas" HorizontalAlignment="Right" Foreground="#4B5563"/>
                                    </Grid>
                                </Border>

                                <!-- Status -->
                                <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="4" Padding="6,4" Margin="0,0,0,6">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding ActiveNozzleText}" FontSize="11" Foreground="#6B7280" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding ControllabilityText}" FontSize="11" Foreground="#6B7280"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Dual Preset Fields: Литры + Сумма -->
                                <Grid Grid.Row="4" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Volume field -->
                                    <Border Grid.Column="0" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                        <StackPanel>
                                            <TextBlock Text="Литры" FontSize="10" Foreground="#6B7280" Margin="0,0,0,2"/>
                                            <TextBox FontSize="18" FontFamily="Consolas" BorderThickness="0"
                                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                     Text="{Binding PresetVolumeText, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Amount field -->
                                    <Border Grid.Column="2" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                        <StackPanel>
                                            <TextBlock Text="Сумма" FontSize="10" Foreground="#6B7280" Margin="0,0,0,2"/>
                                            <TextBox FontSize="18" FontFamily="Consolas" BorderThickness="0"
                                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                     Text="{Binding PresetAmountText, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- СТАРТ + СТОП -->
                                <Grid Grid.Row="5" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Height="38" Content="СТАРТ"
                                            Command="{Binding PostStartCommand}" Style="{StaticResource RoundedBtn}"
                                            Background="#16A34A" Foreground="White" FontWeight="Bold" FontSize="16"/>

                                    <Button Grid.Column="2" Height="38" Content="СТОП"
                                            Command="{Binding PostCancelCommand}" Style="{StaticResource RoundedBtn}"
                                            Background="#DC2626" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                </Grid>

                                <!-- Service Buttons -->
                                <WrapPanel Grid.Row="6" Margin="0,0,0,4">
                                    <Button Margin="0,0,3,3" Padding="8,4" Content="Status" Command="{Binding PostStatusCommand}"
                                            Style="{StaticResource RoundedBtn}" Background="#F3F4F6"/>
                                    <Button Margin="0,0,3,3" Padding="8,4" Content="Totals" Command="{Binding PostTotalsCommand}"
                                            Style="{StaticResource RoundedBtn}" Background="#F3F4F6"/>
                                    <Button Margin="0,0,3,3" Padding="8,4" Content="Lock" Command="{Binding PostLockCommand}"
                                            Style="{StaticResource RoundedBtn}" Background="#FEF3C7" Foreground="#92400E"/>
                                    <Button Margin="0,0,3,3" Padding="8,4" Content="Release" Command="{Binding PostReleaseCommand}"
                                            Style="{StaticResource RoundedBtn}" Background="#F3F4F6"/>
                                </WrapPanel>

                                <!-- Last Frame Info -->
                                <StackPanel Grid.Row="7" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding LastPayload}" FontFamily="Consolas" FontSize="10" Foreground="#9CA3AF"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding LastPayload}"/>
                                    <TextBlock Text="{Binding LastUpdateText}" FontFamily="Consolas" FontSize="10" Foreground="#9CA3AF"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Log Panel -->
            <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="6" Margin="0,8,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Протокол" FontWeight="SemiBold" Foreground="#6B7280" FontSize="12" Margin="4,0,0,4"/>
                    <ListBox ItemsSource="{Binding Log}" FontFamily="Consolas" FontSize="12" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="2,1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
